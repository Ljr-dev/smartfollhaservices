<%- include('../partials/admin-header') %>
<section class="admin-section">
  <h1>Leads</h1>
  <form class="filter-row" method="get">
    <select name="status">
      <option value="">Todos</option>
      <% ['Novo', 'Em atendimento', 'Convertido', 'Perdido'].forEach(function(option) { %>
        <option value="<%= option %>" <%= status === option ? 'selected' : '' %>><%= option %></option>
      <% }) %>
    </select>
    <button type="submit">Filtrar</button>
  </form>
  <table>
    <thead><tr><th>Nome</th><th>E-mail</th><th>Telefone</th><th>Interesse</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% leads.forEach(function(lead) { %>
        <tr>
          <td><%= lead.name %></td>
          <td><%= lead.email %></td>
          <td><%= lead.phone %></td>
          <td><%= lead.service_interest || '-' %></td>
          <td><span class="badge"><%= lead.status %></span></td>
          <td><a href="/admin/leads/<%= lead.id %>">Detalhes</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('../partials/admin-footer') %>
