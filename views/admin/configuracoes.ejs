<%- include('../partials/admin-header') %>
<section class="admin-section narrow">
  <h1>Configurações</h1>
  <form method="post">
    <label>WhatsApp principal<input name="whatsapp_main" value="<%= settings.whatsapp_main || '' %>"></label>
    <label>E-mail de contato<input type="email" name="contact_email" value="<%= settings.contact_email || '' %>"></label>
    <label>Nome da empresa<input name="company_name" value="<%= settings.company_name || '' %>"></label>
    <label>Texto do rodapé<textarea name="footer_text"><%= settings.footer_text || '' %></textarea></label>
    <label>Link do Instagram<input name="instagram_url" value="<%= settings.instagram_url || '' %>"></label>
    <label>Link do LinkedIn<input name="linkedin_url" value="<%= settings.linkedin_url || '' %>"></label>
    <button type="submit">Salvar configurações</button>
  </form>
</section>
<%- include('../partials/admin-footer') %>
