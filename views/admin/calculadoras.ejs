<%- include('../partials/admin-header') %>
<section class="admin-section">
  <div class="section-actions">
    <h1>Calculadoras</h1>
    <a class="button-link" href="/admin/calculadoras/nova">Nova calculadora</a>
  </div>
  <table>
    <thead><tr><th>Nome</th><th>Tipo</th><th>URL</th><th>Ativa</th><th></th></tr></thead>
    <tbody>
      <% calculators.forEach(function(calculator) { %>
        <tr>
          <td><%= calculator.title %></td>
          <td><%= calculator.calculator_type %></td>
          <td>/calculadora-<%= calculator.slug %></td>
          <td><%= calculator.active ? 'Sim' : 'Nao' %></td>
          <td><a href="/admin/calculadoras/<%= calculator.id %>/editar">Editar</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('../partials/admin-footer') %>
