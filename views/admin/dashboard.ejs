<%- include('../partials/admin-header') %>
<section class="admin-section">
  <h1>Dashboard</h1>
  <div class="stats-grid">
    <article><span>Total de leads</span><strong><%= totalLeads %></strong></article>
    <article><span>Leads novos</span><strong><%= novosLeads %></strong></article>
    <article><span>Total de simulações</span><strong><%= totalSimulations %></strong></article>
  </div>
</section>
<section class="admin-section two-cols">
  <div>
    <h2>Simulações por tipo</h2>
    <table>
      <thead><tr><th>Calculadora</th><th>Total</th></tr></thead>
      <tbody>
        <% simulationsByType.forEach(function(item) { %>
          <tr><td><%= item.calculator_type %></td><td><%= item.total %></td></tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div>
    <h2>Últimos contatos recebidos</h2>
    <table>
      <thead><tr><th>Nome</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% latestLeads.forEach(function(lead) { %>
          <tr>
            <td><%= lead.name %></td>
            <td><span class="badge"><%= lead.status %></span></td>
            <td><a href="/admin/leads/<%= lead.id %>">Ver</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('../partials/admin-footer') %>
