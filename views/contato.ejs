<%- include('partials/header') %>

<section class="page-hero">
  <p class="eyebrow">Contato</p>
  <h1><%= page?.heading || 'Fale com a Smart Folha Services' %></h1>
  <p><%= page?.content || 'Conte o que sua empresa precisa revisar ou organizar em folha de pagamento e Departamento Pessoal.' %></p>
</section>

<section class="contact-band single">
  <% if (success) { %><p class="success">Contato enviado com sucesso.</p><% } %>
  <% if (error) { %><p class="alert"><%= error %></p><% } %>
  <form class="contact-form" method="post" action="/contato">
    <input type="hidden" name="source_page" value="contato">
    <label>Nome<input name="name" required></label>
    <label>E-mail<input type="email" name="email" required></label>
    <label>Telefone<input name="phone" required></label>
    <label>Empresa<input name="company"></label>
    <label>Serviço de interesse
      <select name="service_interest">
        <option>BPO de folha de pagamento</option>
        <option>eSocial</option>
        <option>Auditoria de folha</option>
        <option>Treinamento no Sistema Domínio</option>
        <option>Revisão de férias e rescisões</option>
      </select>
    </label>
    <label>Mensagem<textarea name="message" required></textarea></label>
    <button class="btn" type="submit"><%= page?.cta_text || 'Enviar mensagem' %></button>
  </form>
</section>

<%- include('partials/footer') %>
